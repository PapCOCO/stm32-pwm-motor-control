# 这个文件是脚本默认配置。
# 当前项目直接改这里即可。
# 复制到别的项目时，通常只需要改 PROJECT_NAME、CMAKE_TOOLCHAIN_FILE、
# ISP_PORT 这几个值。

: "${PROJECT_NAME:=416}"
: "${BUILD_DIR:=build}"
: "${BUILD_TYPE:=Release}"
: "${CMAKE_GENERATOR:=Ninja}"
: "${CMAKE_TOOLCHAIN_FILE:=cmake/gcc-arm-none-eabi.cmake}"

# 编译前会检查这些命令是否存在。
: "${REQUIRED_BUILD_TOOLS:=arm-none-eabi-gcc cmake ninja}"

# macOS 下 xPack arm-none-eabi-gcc 的常见安装路径。
# 如果你本机工具链不在这里，也没关系，只要 PATH 里能找到即可。
: "${XPACK_GCC_BIN:=$HOME/Library/xPacks/@xpack-dev-tools/arm-none-eabi-gcc/15.2.1-1.1.1/.content/bin}"

# 1: 每次先删除 build 目录再重新编译
# 0: 保留 build 目录，做增量编译
: "${CLEAN_BUILD:=1}"

# UART ISP 烧录默认参数。
: "${ISP_HEX:=$BUILD_DIR/$PROJECT_NAME.hex}"
: "${ISP_PORT:=/dev/cu.usbserial-1140}"
: "${ISP_BAUD:=115200}"
